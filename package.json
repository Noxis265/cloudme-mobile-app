{
  "name": "cloudme",
  "version": "1.1.0",
  "description": "CloudMe — маленькая социальная сеть для друзей",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.cloudme.app",
    "productName": "CloudMe",
    "files": [
      "main.js",
      "index.html",
      "app.js",
      "firebase-config.js"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
